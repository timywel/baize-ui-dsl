{
  "name": "@timywel/baize-ui-dsl",
  "version": "0.1.0",
  "description": "白泽协议原生 UI DSL: Agent 后端 emit 结构化 UI (KPI / 图表 / 表格 / 时间线), 前端按 schema 流式渲染. 8 widget, 零 LLM 依赖, 暗色主题原生.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./widgets": {
      "types": "./dist/widgets/index.d.ts",
      "import": "./dist/widgets/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js"
    },
    "./stream": {
      "types": "./dist/stream/index.d.ts",
      "import": "./dist/stream/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "ui-dsl",
    "agent-ui",
    "streaming-ui",
    "protocol-native",
    "react",
    "baize",
    "kpi",
    "chart",
    "table",
    "timeline"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:lib": "tsc",
    "dev": "vite",
    "dev:docs": "cd docs && npm run dev",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"docs/src/**/*.{ts,tsx,css}\"",
    "preview": "vite preview",
    "prepare": "npm run build:lib",
    "deploy:docs": "cd docs && pnpm build && cd dist && git init -b gh-pages && git add -A && git -c user.email=timywel@163.com -c user.name=timywel commit -m \"deploy: docs build\" && git remote add origin https://github.com/timywel/baize-ui-dsl.git 2>/dev/null; git push -f origin gh-pages"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.0",
    "happy-dom": "^15.7.4",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
